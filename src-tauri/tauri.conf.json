{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slacker Counter",
  "version": "1.0.0",
  "identifier": "com.slacker.counter",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Slacker Counter",
        "width": 480,
        "height": 600,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "上班摸鱼加班计算器",
    "longDescription": "FISHER-PRO 9000 - 上班摸鱼加班计算器桌面端"
  }
}